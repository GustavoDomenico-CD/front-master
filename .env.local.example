# URL do API Nest (repositório irmão).
# https://github.com/GustavoDomenico-CD/backend-edge-main
# Local típico: backend com PORT=3001 (ver .env.example do backend).
BACKEND_URL=http://127.0.0.1:3001

# Opcional: JWT (ex.: usuário admin do Nest) para o servidor Next criar contato em /admin/whatsapp/contacts
# após cadastro público no chatbot — assim o telefone aparece na aba Contatos sem login admin no browser.
# WHATSAPP_CONTACT_SYNC_BEARER_TOKEN=

# Só defina se algum código cliente precisar da URL crua da API (evite expor em produção sem necessidade).
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3001

# Opcional: serviço legado de chat com /health e /reiniciar (ex.: porta 8080). O Chatbot principal usa /api/* + backend acima.
# NEXT_PUBLIC_CHATBOT_SERVICE_URL=

# Google Calendar (servidor Next — service account JSON)
# O arquivo JSON da service account NÃO deve ir para variável NEXT_PUBLIC_* nem para o browser.
# Caminho absoluto ou relativo à raiz do projeto front (ex.: JSON que está no repositório do backend).
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=../backend-edge-main/sodium-diode-480318-q4-f633b3f7e9b6.json
# Calendário a listar (default: primary = calendário da própria service account).
# Para ver o calendário de um usuário, compartilhe-o com o e-mail client_email do JSON.
# GOOGLE_CALENDAR_ID=primary
