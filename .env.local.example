# URL do API Nest (repositório irmão).
# https://github.com/GustavoDomenico-CD/backend-edge-main
# Local típico: backend com PORT=3001 (ver .env.example do backend).
BACKEND_URL=http://127.0.0.1:3001

# Só defina se algum código cliente precisar da URL crua da API (evite expor em produção sem necessidade).
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:3001

# Opcional: serviço legado de chat com /health e /reiniciar (ex.: porta 8080). O Chatbot principal usa /api/* + backend acima.
# NEXT_PUBLIC_CHATBOT_SERVICE_URL=
